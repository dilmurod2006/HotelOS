sequenceDiagram
    autonumber

    %% ═══════════════════════════════════════════════════════
    %% PARTICIPANTS
    %% ═══════════════════════════════════════════════════════

    actor Client1 as Client 1 (Booking A)
    actor Client2 as Client 2 (Booking B)
    participant API as BookingController
    participant MediatR as MediatR Pipeline
    participant Handler as CreateBookingCommandHandler
    participant Redis as Redis<br/>(RedLock + Cache)
    participant DB as PostgreSQL<br/>(EF Core + RowVersion)
    participant SignalR as DashboardHub<br/>(SignalR)
    participant BG as AutoReleaseWorker<br/>(BackgroundService)

    Note over Client1,Client2: 1000+ concurrent requests for Room 101

    %% ═══════════════════════════════════════════════════════
    %% PHASE 1 — HTTP INGRESS
    %% ═══════════════════════════════════════════════════════

    rect rgb(235, 245, 255)
        Note over Client1,API: Phase 1 · HTTP Ingress & JWT Auth
        Client1 ->> API: POST /api/bookings<br/>{ roomId, guestId, checkIn, checkOut }<br/>Authorization: Bearer JWT
        Client2 ->> API: POST /api/bookings<br/>{ same roomId, overlapping dates }<br/>Authorization: Bearer JWT
        API ->> API: ValidateJwt()<br/>FluentValidation.Validate()
        API ->> MediatR: Send(CreateBookingCommand)
        Note right of API: Both requests enter MediatR pipeline simultaneously
    end

    %% ═══════════════════════════════════════════════════════
    %% PHASE 2 — REDIS DISTRIBUTED LOCK (RedLock.net)
    %% ═══════════════════════════════════════════════════════

    rect rgb(255, 251, 235)
        Note over Handler,Redis: Phase 2 · Redis Distributed Lock (RedLock.net)
        MediatR ->> Handler: HandleAsync(command) [×2 concurrent]

        Handler ->> Redis: ACQUIRE lock<br/>key: "booking:room:{roomId}"<br/>ttl: 10s · timeout: 5s
        Note over Redis: RedLock algorithm<br/>attempts lock on N Redis nodes<br/>majority quorum required

        alt Lock acquired by Client 1 first
            Redis -->> Handler: ILockHandle { IsAcquired = true }
            Note over Handler: Client 1 holds lock ✓<br/>Client 2 is WAITING...

            Handler ->> Redis: ACQUIRE lock (Client 2)
            Redis -->> Handler: Waiting... (timeout: 5s)
        else All Redis nodes unavailable
            Redis -->> Handler: ILockHandle { IsAcquired = false }
            Handler -->> API: Result.Failure(Error.Unavailable)
            API -->> Client1: 503 Service Unavailable<br/>{ "error": "booking_lock_unavailable" }
        end
    end

    %% ═══════════════════════════════════════════════════════
    %% PHASE 3 — REDIS CACHE-ASIDE (Client 1, holds lock)
    %% ═══════════════════════════════════════════════════════

    rect rgb(236, 253, 245)
        Note over Handler,Redis: Phase 3 · Cache-Aside Pattern (Client 1 · Lock Held)

        Handler ->> Redis: GET "room:{roomId}"
        Note over Redis: TTL: 60 seconds

        alt Cache HIT
            Redis -->> Handler: Room entity (deserialized)
            Note over Handler: Cache hit — skip DB read ✓
        else Cache MISS
            Redis -->> Handler: null
            Handler ->> DB: SELECT * FROM "Rooms"<br/>WHERE "Id" = roomId
            DB -->> Handler: Room { Status=Available, RowVersion=42 }
            Handler ->> Redis: SET "room:{roomId}" = Room<br/>EX 60
        end

        Handler ->> Handler: Validate Room.Status == Available<br/>Validate DateRange not expired
    end

    %% ═══════════════════════════════════════════════════════
    %% PHASE 4 — EF CORE OPTIMISTIC CONCURRENCY
    %% ═══════════════════════════════════════════════════════

    rect rgb(254, 242, 242)
        Note over Handler,DB: Phase 4 · EF Core Optimistic Concurrency (RowVersion)

        Handler ->> DB: BEGIN TRANSACTION (SERIALIZABLE)

        Handler ->> DB: SELECT * FROM "Bookings"<br/>WHERE "RoomId" = roomId<br/>AND "CheckOut" > checkIn<br/>AND "CheckIn" < checkOut<br/>AND "Status" NOT IN (Cancelled, CheckedOut)<br/>(Overlap check — atomic)

        alt No overlapping bookings
            DB -->> Handler: [] (empty result)

            Handler ->> Handler: Booking.Create(guestId, roomId, dateRange, totalPrice)

            Handler ->> DB: INSERT INTO "Bookings" (new booking)<br/>UPDATE "Rooms" SET "Status" = Occupied<br/>WHERE "Id" = roomId<br/>AND "RowVersion" = 42
            Note over DB: PostgreSQL checks RowVersion<br/>(xmin / bytea concurrency token)<br/>Atomic compare-and-swap

            alt RowVersion matches (no concurrent update)
                DB -->> Handler: 1 row affected · commit OK
                Handler ->> DB: COMMIT TRANSACTION
                Note over Handler: Booking created successfully ✓
            else RowVersion mismatch (concurrent update detected!)
                DB -->> Handler: DbUpdateConcurrencyException
                Handler ->> DB: ROLLBACK TRANSACTION
                Handler -->> API: Result.Failure(Error.Conflict)
                API -->> Client1: 409 Conflict<br/>{ "error": "room_concurrency_conflict",<br/>  "message": "Room status changed — please retry" }
            end

        else Overlapping booking EXISTS
            DB -->> Handler: [existingBooking]
            Handler ->> DB: ROLLBACK TRANSACTION
            Handler -->> API: Result.Failure(Error.Conflict)
            API -->> Client1: 409 Conflict<br/>{ "error": "room_already_booked" }
        end
    end

    %% ═══════════════════════════════════════════════════════
    %% PHASE 5 — POST-COMMIT (Client 1 success path)
    %% ═══════════════════════════════════════════════════════

    rect rgb(240, 253, 250)
        Note over Handler,SignalR: Phase 5 · Post-Commit — Cache Invalidation + Real-Time Broadcast

        Handler ->> Redis: DEL "room:{roomId}"
        Note right of Redis: Invalidate stale cache<br/>Next read will reload from DB

        Handler ->> SignalR: NotifyRoomStatusChanged(<br/>  roomId, "Available", "Occupied"<br/>)
        SignalR -->> Client1: WS: RoomStatusChanged event
        SignalR -->> Client2: WS: RoomStatusChanged event
        Note over SignalR: All connected staff dashboards<br/>receive real-time update instantly

        Handler ->> Redis: RELEASE lock "booking:room:{roomId}"
        Note over Redis: Lock released — Client 2 can now proceed

        Handler -->> API: Result.Success(bookingId)
        API -->> Client1: 201 Created<br/>{ "bookingId": "...", "status": "Pending",<br/>  "totalPrice": 299.00, "expiresAt": "+15min" }
    end

    %% ═══════════════════════════════════════════════════════
    %% CLIENT 2 — LOCK ACQUIRED AFTER CLIENT 1 RELEASES
    %% ═══════════════════════════════════════════════════════

    rect rgb(253, 242, 255)
        Note over Handler,DB: Client 2 · Acquires Lock After Client 1 Releases

        Redis -->> Handler: ILockHandle { IsAcquired = true } (Client 2 now holds lock)

        Handler ->> Redis: GET "room:{roomId}"
        Note over Redis: Cache was invalidated by Client 1<br/>→ Cache MISS

        Handler ->> DB: SELECT Room WHERE Id = roomId
        DB -->> Handler: Room { Status = Occupied, RowVersion = 43 }

        Handler ->> Handler: Room.Status != Available → REJECT

        Handler ->> Redis: RELEASE lock "booking:room:{roomId}"
        Handler -->> API: Result.Failure(Error.Conflict)
        API -->> Client2: 409 Conflict<br/>{ "error": "room_not_available",<br/>  "message": "Room 101 is already booked" }
    end

    %% ═══════════════════════════════════════════════════════
    %% BACKGROUND WORKER — AUTO-RELEASE EXPIRED BOOKINGS
    %% ═══════════════════════════════════════════════════════

    rect rgb(249, 250, 251)
        Note over BG,DB: Background · AutoReleaseBackgroundService (every 5 minutes)

        BG ->> BG: ExecuteAsync(CancellationToken)
        loop Every 5 minutes
            BG ->> DB: SELECT * FROM "Bookings"<br/>WHERE "Status" = Pending<br/>AND "ExpiresAt" < NOW()
            DB -->> BG: [expiredBookings]

            loop For each expired booking
                BG ->> DB: UPDATE "Bookings" SET Status = Cancelled<br/>UPDATE "Rooms" SET Status = Available<br/>WHERE RowVersion matches
                BG ->> Redis: DEL "room:{roomId}"
                BG ->> SignalR: NotifyRoomStatusChanged(<br/>  roomId, "Occupied", "Available"<br/>)
                Note over SignalR: Dashboard updated in real-time
            end
        end
    end

    Note over Client1,BG: Result: Zero double-bookings · Zero deadlocks · Zero UI freeze<br/>RedLock serializes concurrent requests · RowVersion catches edge cases · Cache reduces DB load by ~80%
